rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 주인(관리자) 이메일 — index.html 의 window.SHARE.owner 와 동일하게 유지하세요.
    // 보안 규칙은 클라이언트 설정을 읽을 수 없어, 주인 이메일은 여기에도 한 번 적어야 합니다.
    function isOwner() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['dlgur2419304@gmail.com'];
    }

    // 허용된 선생님 = 주인이거나, teachers 컬렉션에 이메일 문서가 있는 경우
    function isTeacher() {
      return request.auth != null && request.auth.token.email_verified == true
        && (isOwner() || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email)));
    }

    // 학원 공유 데이터: 허용된 선생님만 읽기/쓰기
    match /academy/{docId} {
      allow read, write: if isTeacher();
    }

    // 선생님 명단: 로그인 사용자는 자기 접근권한 확인용으로 읽기 가능, 추가/삭제는 주인만
    match /teachers/{email} {
      allow read: if request.auth != null;
      allow write: if isOwner();
    }

    // 활동 로그: 허용된 선생님이 '본인 이메일로만' 추가 가능(append-only),
    // 열람은 주인만, 수정·삭제는 누구도 불가.
    match /logs/{logId} {
      allow create: if isTeacher() && request.resource.data.email == request.auth.token.email;
      allow read: if isOwner();
      allow update, delete: if false;
    }
  }
}
